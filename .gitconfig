[user]
	name = iton0
	email = iton442@gmail.com
[core]
	editor = nvim
	autocrlf = input
	whitespace = space-before-tab
[init]
	defaultBranch = main
[color]
	ui = true
[credential]
	helper = cache
[alias]
	p = push
	pl = pull
	st = status -sb
	last = log -1 HEAD --stat
	cm = commit -v
	rl = remote -v
	dv = difftool -t nvimdiff -y
	se = !git rev-list --all | xargs git grep -F
	gl = config --global -l
        unstage = restore --staged
