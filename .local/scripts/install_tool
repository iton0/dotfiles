#!/bin/bash

# Make sure in the home directory
cd

# Update package list
sudo apt update

# Install Git, Vim, Tmux, Zsh
sudo apt install -y vim tmux zsh

# Check if installations were successful
if [ $? -ne 0 ]; then
    echo "Error: Installation of Vim, Tmux, Zsh failed."
    exit 1
fi

# Set Zsh as the default shell and start Zsh
chsh -s $(which zsh)
zsh

echo "Tools (Vim, Tmux, Zsh) installed successfully."
echo "--------------------------------"

# Install lazygit
echo "Installing LazyGit"
LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
tar xf lazygit.tar.gz lazygit
sudo install lazygit /usr/local/bin
echo "Current LazyGit version:"
lazygit --version
rm lazygit.tar.gz
echo "--------------------------------"

# Prompt to continue for Neovim installation
echo "Installing Neovim"
curl -LO "https://github.com/neovim/neovim/releases/download/stable/nvim-linux64.tar.gz"
tar xzvf nvim-linux64.tar.gz
sudo rm -rf /opt/nvim-linux64/
echo "--------------------------------"
echo "Old version deleted"
sudo mv ~/nvim-linux64 /opt
echo "--------------------------------"
echo "Current Neovim version:"
nvim --version
rm nvim-linux64.tar.gz
