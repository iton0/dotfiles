#!/usr/bin/env bash

set -e

# Update dependencies
sudo apt update

# Define list of packages to install
packages=("unzip" "make" "zsh" "fzf" "sed" "ripgrep" "xclip" "gcc" "python3.10-venv")

# Install all packages
sudo apt install -y "${packages[@]}"

echo "Tools installed successfully..."

# Upgrade packages
sudo apt upgrade -y

# Install oh-my-zsh
sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended --keep-zshrc

# Clone zsh plugins
git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions
git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting

echo "Zsh configured successfully."

# Install nvm
echo "Installing nvm..."
curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash

# Starship prompt
curl -sS https://starship.rs/install.sh | sh

# Install Neovim
echo "Installing Neovim..."
curl -LO https://github.com/neovim/neovim/releases/latest/download/nvim-linux64.tar.gz
sudo rm -rf /opt/nvim-linux64
sudo mkdir -p /opt/nvim-linux64
sudo chmod a+rX /opt/nvim-linux64
sudo tar -C /opt -xzf nvim-linux64.tar.gz
# Make it available in /usr/local/bin, distro installs to /usr/bin
sudo ln -sf /opt/nvim-linux64/bin/nvim /usr/local/bin/
echo "Neovim installed successfully."
/opt/nvim-linux64/bin/nvim --version
rm nvim-linux64.tar.gz

# Create directories
echo "Creating directories..."
mkdir -p "$HOME/Code/personal"
mkdir -p "$HOME/Code/neovim_dev"
mkdir -p "$HOME/Code/work"
mkdir -p "$HOME/Code/sandbox"
mkdir -p "$HOME/.local/bin"

echo -e "\n---------------------------"
echo -e "Main installation finished!\n"
echo -e "\033[1m[IMPORTANT]\033[0m\n"
echo -e "Run '\033[4mchsh -s \$(which zsh)\033[0m' before rebooting & '\033[4mnvm install --lts\033[0m' after rebooting\n"
echo -e "Reboot system and check"
echo -e "'Post Install' of dotfiles wiki"
