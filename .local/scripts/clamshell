#!/usr/bin/env bash

# 1. Configuration
LAPTOP_OUTPUT="eDP-1"

# 2. Dynamic Lid Detection
# This finds the lid state file even if it's named LID0, LID, or LIDA
LID_STATE_FILE=$(find /proc/acpi/button/lid -name state | head -n 1)

if [[ -z "$LID_STATE_FILE" ]]; then
    echo "Error: Lid state file not found." >&2
    exit 1
fi

# 3. Logic
# We use grep -q for a faster, cleaner check than variable reading
if grep -q "open" "$LID_STATE_FILE"; then
    swaymsg output "$LAPTOP_OUTPUT" enable
elif grep -q "closed" "$LID_STATE_FILE"; then
    swaymsg output "$LAPTOP_OUTPUT" disable
else
    echo "Could not determine lid state from $LID_STATE_FILE" >&2
    exit 1
fi
