#!/usr/bin/env bash

# --- SwayNC Style Setup Script ---

CONFIG_DIR="$HOME/.config/swaync"
STYLE_FILE="$CONFIG_DIR/style.css"

echo "Checking for directory: $CONFIG_DIR"

# 1. Create the directory structure if it doesn't exist (-p flag prevents errors if it already exists)
mkdir -p "$CONFIG_DIR"

if [ $? -eq 0 ]; then
    echo "Directory created or already exists."
else
    echo "Error: Could not create directory $CONFIG_DIR. Exiting."
    exit 1
fi

echo "Writing CSS content to: $STYLE_FILE"

# 2. Write the custom CSS content to the style.css file using a heredoc
cat << EOF > "$STYLE_FILE"
/*
 * Custom styles for Sway Notification Center (swaync)
 * Generated by the setup script.
 */

/* Styling for the Notification Title/Summary */
.notification-content .summary {
    /* Set the font size for the notification title */
    font-size: 1.1rem; /* Adjust this value (e.g., 1.2rem, 14px, 16px) */
    font-weight: bold; /* Optional: Make the title stand out */
    color: #ffffff; /* Example: Change color if desired */
}
/* Styling for the Notification Body/Content */
.notification-content .body {
    /* Set the font size for the main body text */
    font-size: 1.0rem; /* Adjust this value to be bigger than the default */
    color: #cccccc; /* Example: Change color if desired */
}
EOF

if [ $? -eq 0 ]; then
    echo "Successfully created and populated $STYLE_FILE"
    echo "You can now restart swaync or your window manager to apply the changes."
else
    echo "Error: Failed to write content to $STYLE_FILE."
fi

exit 0
