#!/usr/bin/env bash
set -euo pipefail

echo "Creating development directory structure..."

# Define project roots
PROJECT_PATHS=(
    "$HOME/Code/personal"
    "$HOME/Code/work"
    "$HOME/Code/testing"
)

for path in "${PROJECT_PATHS[@]}"; do
    if [[ ! -d "$path" ]]; then
        mkdir -p "$path"
        echo "  [+] Created $path"
    fi
done

echo "Development environment ready."
