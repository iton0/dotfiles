#!/usr/bin/env bash
mkdir -p "$HOME/.local/bin"
if command -v pacman >/dev/null 2>&1; then # Arch
	if [ "$(cat /sys/class/dmi/id/sys_vendor)" == "System76" ]; then
		sudo pacman -S --needed base-devel git linux-headers
		git clone https://aur.archlinux.org/system76-firmware.git
		cd system76-firmware
		makepkg -srcif
		sudo systemctl enable --now system76-firmware-daemon
		sudo gpasswd -a $USER adm
		git clone https://aur.archlinux.org/firmware-manager.git
		cd firmware-manager
		makepkg -srcif
		git clone https://aur.archlinux.org/system76-driver.git
		cd system76-driver
		makepkg -srcif
		sudo systemctl enable --now system76
	fi
	BASE_PACKAGES=( "brightnessctl" "sway" "swaylock" "swayidle" "fzf" "sed" "vim" "ripgrep" "wl-clipboard" "gcc" "fd" "thunar" "firefox" "wofi" "gvfs" "less" "man-db" "ufw" "evince" "calibre" "playerctl" "waybar" "otf-font-awesome")
	# Install all packages
	echo "Installing base packages..."
	sudo pacman -S --needed "${BASE_PACKAGES[@]}"
	sudo pacman -Syu --noconfirm
	if command -v fd >/dev/null; then
		ln -s "$(command -v fd)" "$HOME/.local/bin/fd"
	else
		echo "fd is not installed, skipping symlink creation."
	fi
elif command -v apt >/dev/null 2>&1; then # Ubuntu
	# Check if the system vendor is System76
	if [ "$(cat /sys/class/dmi/id/sys_vendor)" == "System76" ]; then
		sudo apt-add-repository -y ppa:system76-dev/stable
		sudo apt-get update
		sudo apt install system76-driverfi
	fi
	# Define list of base packages to install
	BASE_PACKAGES=( "vim" "pulseaudio" "brightnessctl" "fonts-font-awesome" "ufw" "playerctl" "waybar" "wl-clipboard" "wofi" "evince" "calibre" "sway" "swaylock" "swayidle" "fd-find" "fzf" "sed" "ripgrep" "gcc" "g++-12" )
	# Install all packages
	echo "Installing base packages..."
	sudo apt install -y "${BASE_PACKAGES[@]}"
	# Upgrade packages
	echo "Upgrading packages..."
	sudo apt upgrade -y
	# Recommended by creator of fd
	if command -v fdfind >/dev/null; then
		ln -s "$(command -v fdfind)" "$HOME/.local/bin/fd"
	else
		echo "fdfind is not installed, skipping symlink creation."
	fi
else
	if [ "$(cat /sys/class/dmi/id/sys_vendor)" == "System76" ]; then
		sudo dnf copr enable szydell/system76
		sudo dnf install system76-driver
		sudo dnf install system76* firmware-manager
		sudo systemctl enable --now system76-firmware-daemon
		sudo systemctl mask power-profiles-daemon.service
		sudo gpasswd -a $USER adm
	fi
# Define list of base packages to install for Fedora
	BASE_PACKAGES=( "vim" "pulseaudio" "brightnessctl" "ufw" "playerctl" "waybar" "wl-clipboard" "wofi" "evince" "calibre" "sway" "swaylock" "swayidle" "fd-find" "fzf" "sed" "ripgrep" "gcc" "g++" )

	# Install all packages using dnf
	echo "Installing base packages for Fedora..."
	sudo dnf install -y "${BASE_PACKAGES[@]}"

	# Upgrade packages
	echo "Upgrading packages..."
	sudo dnf upgrade -y

	# Enable dark mode for most applications
	gsettings set org.gnome.desktop.interface gtk-theme "Adwaita-dark"

	# Create symlink for fd-find (same functionality as 'fd' on other distros)
	if command -v fd >/dev/null; then
		ln -s "$(command -v fd)" "$HOME/.local/bin/fd"
	else
		echo "fd is not installed, skipping symlink creation."
	fi
fi
if ! grep -qiE "(Microsoft|WSL)" /proc/version; then
	# Enable firewall
	sudo ufw enable
fi
