#!/usr/bin/env bash

set -euo pipefail

PACKAGE_FILE="$HOME/.local/scripts/new_machine_setup/packages.txt"

# --- 1. Validation ---
if [[ ! -f "$PACKAGE_FILE" ]]; then
    echo "Error: Package list file $PACKAGE_FILE not found." >&2
    exit 1
fi

mapfile -t BASE_PACKAGES < <(grep -vE '^\s*#|^\s*$' "$PACKAGE_FILE")

if [[ ${#BASE_PACKAGES[@]} -eq 0 ]]; then
    echo "No packages found in $PACKAGE_FILE. Nothing to install."
    exit 0
fi

# --- 2. System76 Hardware Support ---
if grep -qi "System76" /sys/class/dmi/id/sys_vendor 2>/dev/null; then
    echo "System76 hardware detected. Configuring drivers..."

    # Idempotent COPR enable
    sudo dnf copr enable szydell/system76 -y
    
    # DNF is naturally idempotent; it won't reinstall if already present
    sudo dnf install -y "kernel-devel-$(uname -r)"
    sudo dnf install -y system76-driver system76-power firmware-manager system76-acpi-dkms

    # Masking is idempotent
    sudo systemctl mask power-profiles-daemon.service
    
    # enable --now is idempotent
    sudo systemctl enable --now system76-firmware-daemon
    sudo systemctl enable --now com.system76.PowerDaemon.service system76-power-wake
    sudo systemctl enable dkms

    # Idempotent group addition: check if user is already in group
    if ! groups "$USER" | grep -q "\badm\b"; then
        sudo gpasswd -a "$USER" adm
    fi
fi

# --- 3. Repositories & Base Packages ---
echo "Checking COPR repositories..."
REPOS=(solopasha/hyprland scottames/ghostty jdxcode/mise erikreider/SwayNotificationCenter atim/starship)

# To be truly idempotent/fast, check if the repo file already exists in /etc/dnf/
for repo in "${REPOS[@]}"; do
    # COPR names are stored as 'user-repo.repo' in dnf
    REPO_FILENAME="${repo/\//-}"
    if [[ ! -f "/etc/yum.repos.d/_copr:$REPO_FILENAME.repo" ]]; then
        echo "Enabling COPR: $repo"
        sudo dnf copr enable "$repo" -y
    fi
done

echo "Installing base packages..."
# DNF handles idempotency (skips installed)
sudo dnf install -y "${BASE_PACKAGES[@]}"

# --- 4. Source Compilations (SwayAudioIdleInhibit) ---

if ! command -v sway-audio-idle-inhibit &> /dev/null; then
    echo "Building SwayAudioIdleInhibit..."
    TEMP_BUILD_DIR=$(mktemp -d)
    git clone --depth 1 https://github.com/ErikReider/SwayAudioIdleInhibit.git "$TEMP_BUILD_DIR"
    
    (
        cd "$TEMP_BUILD_DIR"
        meson setup build -Dlogind-provider=systemd
        meson compile -C build
        sudo meson install -C build
    )
    rm -rf "$TEMP_BUILD_DIR"
else
    echo "SwayAudioIdleInhibit already installed. Skipping build."
fi

echo "All tasks completed successfully."
