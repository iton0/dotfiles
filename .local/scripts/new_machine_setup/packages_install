#!/usr/bin/env bash

mkdir -p "$HOME/.local/bin"

if command -v pacman >/dev/null 2>&1; then # Arch
	BASE_PACKAGES=( "fzf" "sed" "ripgrep" "wl-clipboard" "gcc" "fd" "thunar" "firefox" "wofi" "gvfs" "less" "man-db" "ufw" "evince" "calibre" "playerctl" "waybar" "otf-font-awesome")

	# Install all packages
	echo "Installing base packages..."
	sudo pacman -Sy "${BASE_PACKAGES[@]}"

	sudo pacman -Syu

	if command -v fd >/dev/null; then
		ln -s "$(command -v fd)" "$HOME/.local/bin/fd"
	else
		echo "fd is not installed, skipping symlink creation."
	fi
else # Other Linux-based
	# Define list of base packages to install
	BASE_PACKAGES=( "fonts-font-awesome" "ufw" "playerctl" "waybar" "wl-clipboard" "wofi" "evince" "calibre" "sway" "fd-find" "fzf" "sed" "ripgrep" "xclip" "gcc" "g++-12" )

	# Install all packages
	echo "Installing base packages..."
	sudo apt install -y "${BASE_PACKAGES[@]}"

	# Upgrade packages
	echo "Upgrading packages..."
	sudo apt upgrade -y

	# Recommended by creator of fd
	if command -v fdfind >/dev/null; then
		ln -s "$(command -v fdfind)" "$HOME/.local/bin/fd"
	else
		echo "fdfind is not installed, skipping symlink creation."
	fi
fi

# Enable firewall
sudo ufw enable
sudo ufw start
