#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status.
set -euo pipefail

FONT_NAME="JetBrainsMono"
FONT_DIR="$HOME/.local/share/fonts"
FONT_URL="https://github.com/ryanoasis/nerd-fonts/releases/latest/download/${FONT_NAME}.zip"
ZIP_FILE="${FONT_NAME}.zip"

# Check for required commands
if ! command -v wget &> /dev/null; then
    sudo dnf install -y wget
fi
if ! command -v unzip &> /dev/null; then
    sudo dnf install -y unzip
fi

echo "Downloading ${FONT_NAME} Nerd Font..."
wget -q --show-progress "$FONT_URL" -O "$ZIP_FILE"

# Create font directory if it doesn't exist
echo "Creating font directory: $FONT_DIR"
mkdir -p "$FONT_DIR"

echo "Extracting fonts to a temporary directory..."
TEMP_DIR=$(mktemp -d)
unzip -q "$ZIP_FILE" -d "$TEMP_DIR"

echo "Moving fonts to the correct directory..."
# Find all font files and move them
find "$TEMP_DIR" -name "*.[ot]tf" -exec mv -t "$FONT_DIR" {} +

echo "Cleaning up temporary files..."
rm -rf "$TEMP_DIR" "$ZIP_FILE"

echo "Updating font cache..."
fc-cache -fv
