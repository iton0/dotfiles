#!/usr/bin/env bash
set -euo pipefail

# Configuration
FONT_NAME="JetBrainsMono"
FONT_DIR="$HOME/.local/share/fonts/nerd-fonts" # Use a sub-dir to keep ~/.local/share/fonts clean
# The URL for the latest release usually requires a specific format
FONT_URL="https://github.com/ryanoasis/nerd-fonts/releases/latest/download/${FONT_NAME}.zip"

# --- 1. Dependency Check ---
# Using a loop is a bit more 'idiomatic' for multiple tools
for cmd in wget unzip; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Installing $cmd..."
        sudo dnf install -y "$cmd"
    fi
done

# --- 2. Download and Extract ---
# Use mktemp for the zip file too, to keep your current directory clean
TEMP_DIR=$(mktemp -d)
ZIP_FILE="$TEMP_DIR/${FONT_NAME}.zip"

echo "Downloading ${FONT_NAME} Nerd Font..."
# -L is important in case GitHub redirects the download
wget -q --show-progress "$FONT_URL" -O "$ZIP_FILE"

echo "Extracting fonts..."
# Extract directly into a scoped directory within the temp dir
unzip -q "$ZIP_FILE" -d "$TEMP_DIR/extracted"

# --- 3. Install ---
echo "Installing fonts to $FONT_DIR..."
mkdir -p "$FONT_DIR"

# Using 'cp -u' (update) prevents overwriting if files haven't changed
# and 'find' ensures we grab both OpenType and TrueType fonts
find "$TEMP_DIR/extracted" -type f \( -name "*.ttf" -o -name "*.otf" \) -exec cp -u {} "$FONT_DIR/" \;

# --- 4. Cleanup & Cache ---
echo "Cleaning up..."
rm -rf "$TEMP_DIR"

echo "Updating font cache..."
# -f is only needed if you think the cache is corrupt; usually 'fc-cache' is enough
fc-cache -f "$FONT_DIR"

echo "${FONT_NAME} Nerd Font installed successfully!"
