#!/usr/bin/env bash
set -euo pipefail

# Configuration
FONT_NAME="JetBrainsMono"
FONT_DIR="$HOME/.local/share/fonts/nerd-fonts"
FONT_URL="https://github.com/ryanoasis/nerd-fonts/releases/latest/download/${FONT_NAME}.zip"

# --- 1. Idempotency Check ---
# Checks if the target directory exists and if any matching font files are inside.
# -print -quit makes it lightning fast by stopping at the first match.
if [ -d "$FONT_DIR" ]; then
    if [ -n "$(find "$FONT_DIR" -type f -iname "*${FONT_NAME}*" -print -quit)" ]; then
        echo "✅ ${FONT_NAME} Nerd Font is already installed in ${FONT_DIR}."
        echo "Exiting without making changes."
        exit 0
    fi
fi

# --- 2. Dependency Check ---
# Idiomatic Fedora check (rpm -q) rather than generic binary checks
for pkg in unzip curl; do
    rpm -q "$pkg" &>/dev/null || sudo dnf install -y "$pkg"
done

# --- 3. Temp Workspace Setup ---
# Robust cleanup that triggers automatically on exit, success, or failure (Ctrl+C)
TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

# --- 4. Download & Extract ---
echo "Downloading $FONT_NAME..."
# -f fails silently on server errors, -L follows redirects, -o writes to file
curl -fLo "$TEMP_DIR/font.zip" "$FONT_URL"

echo "Extracting..."
unzip -q "$TEMP_DIR/font.zip" -d "$TEMP_DIR"

# --- 5. Smart Install ---
mkdir -p "$FONT_DIR"

# Optimal move: grabs only font files and batches them into a single 'mv' command
find "$TEMP_DIR" -type f \( -iname "*.ttf" -o -iname "*.otf" \) -exec mv -t "$FONT_DIR/" {} +

# --- 6. Refresh Cache ---
echo "Refreshing font cache..."
fc-cache -f

echo "$FONT_NAME Nerd Font is ready to use!"
