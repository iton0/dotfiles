#!/usr/bin/env bash
set -euo pipefail

DEST_DIR="/usr/share/wayland-sessions"
DEST_FILE="$DEST_DIR/sway-uwsm.desktop"

# Ensure the directory exists
if [[ ! -d "$DEST_DIR" ]]; then
    echo "Creating wayland-sessions directory..."
    sudo mkdir -p "$DEST_DIR"
fi

echo "Generating Sway UWSM desktop entry..."

# We use 'sudo tee' to write the file, but we use a quoted 'EOF'
# to prevent the shell from trying to expand variables inside the document.
sudo tee "$DEST_FILE" > /dev/null << 'EOF'
[Desktop Entry]
Name=Sway (UWSM)
Comment=An i3-compatible Wayland compositor managed by UWSM
Exec=uwsm start -- sway.desktop
Type=Application
DesktopNames=sway
EOF

# Ensure permissions are correct (readable by everyone)
sudo chmod 644 "$DEST_FILE"

echo "Successfully created '$DEST_FILE'."
