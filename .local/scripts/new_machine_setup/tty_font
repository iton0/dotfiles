#!/usr/bin/env bash

# This script changes the virtual console (TTY) font to 'ter-v32n'.
# It uses the /etc/vconsole.conf file, which is the standard method
# for systems using systemd.

# Define the font you want to set
NEW_FONT="ter-v32n"

# Check if /etc/vconsole.conf exists
if [ ! -f "/etc/vconsole.conf" ]; then
    echo "Creating /etc/vconsole.conf..."
    # The file doesn't exist, so create it with the new font setting.
    sudo sh -c "echo FONT=$NEW_FONT > /etc/vconsole.conf"
    echo "FONT=$NEW_FONT" | sudo tee /etc/vconsole.conf > /dev/null
else
    echo "Modifying /etc/vconsole.conf..."
    # The file exists, so replace or add the FONT line.
    # The sed command handles both cases:
    # 1. If FONT= line exists, it's replaced.
    # 2. If it doesn't, a new line is added at the end.
    sudo sed -i '/^FONT=/cFONT='$NEW_FONT'' /etc/vconsole.conf
    # The 'c' command in sed is "change". It replaces the entire line that starts with FONT=.
fi

# Inform the user of the change
echo "The console font has been set to '$NEW_FONT' in /etc/vconsole.conf."
echo "The change will take effect on the next reboot."
