#!/usr/bin/env bash
set -Eeuo pipefail

START_THRESHOLD=50
END_THRESHOLD=60

# --- Helper: Find Battery ---
# Returns BAT0, BAT1, etc.
find_battery_device() {
    for bat_dir in /sys/class/power_supply/BAT*; do
        if [ -d "$bat_dir" ]; then
            basename "$bat_dir"
            return 0
        fi
    done
    return 1
}

echo "--- Battery Charge Threshold Setup ---"

# 1. Hardware Check: System76
if [[ -f /sys/class/dmi/id/sys_vendor ]] && grep -qi "System76" /sys/class/dmi/id/sys_vendor; then
    echo "System76 detected. Using system76-power."
    if command -v system76-power &> /dev/null; then
        sudo system76-power charge-thresholds "$START_THRESHOLD" "$END_THRESHOLD"
        echo "Thresholds set via system76-power daemon."
        exit 0
    else
        echo "Error: system76-power not found." >&2
        exit 1
    fi
fi

# 2. Hardware Check: Generic Laptop
BAT_DEV=$(find_battery_device) || {
    echo "Notice: No battery (BAT*) detected. Skipping threshold setup (likely a Desktop/VM)."
    exit 0
}

echo "Found battery: $BAT_DEV"

# Determine which files exist
START_FILE=""
END_FILE=""

# Check potential start files
for f in "/sys/class/power_supply/$BAT_DEV/charge_control_start_threshold" "/sys/class/power_supply/$BAT_DEV/charge_start_threshold"; do
    [[ -f "$f" ]] && START_FILE="$f" && break
done

# Check potential end files
for f in "/sys/class/power_supply/$BAT_DEV/charge_control_end_threshold" "/sys/class/power_supply/$BAT_DEV/charge_stop_threshold"; do
    [[ -f "$f" ]] && END_FILE="$f" && break
done

if [[ -z "$END_FILE" ]]; then
    echo "Notice: This hardware does not appear to support sysfs battery thresholds. Skipping."
    exit 0
fi

# 3. Apply settings and create Service
echo "Setting temporary thresholds..."
[[ -n "$START_FILE" ]] && echo "$START_THRESHOLD" | sudo tee "$START_FILE" >/dev/null || true
echo "$END_THRESHOLD" | sudo tee "$END_FILE" >/dev/null

echo "Installing systemd persistence service..."
SERVICE_FILE="/etc/systemd/system/battery-threshold.service"

# Construct the command for the service (Systemd runs as root, so no sudo needed)
CMD=""
[[ -n "$START_FILE" ]] && CMD="echo $START_THRESHOLD > $START_FILE; "
CMD="${CMD}echo $END_THRESHOLD > $END_FILE"

sudo tee "$SERVICE_FILE" > /dev/null <<EOF
[Unit]
Description=Set battery charging thresholds
After=multi-user.target suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target

[Service]
Type=oneshot
ExecStart=/usr/bin/sh -c '$CMD'

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable --now battery-threshold.service

echo "✅ Battery thresholds configured ($START_THRESHOLD% - $END_THRESHOLD%)."
