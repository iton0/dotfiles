#!/usr/bin/env bash

# -e: stop on error, -u: error on unset vars
set -euo pipefail

# Define script directory for easier maintenance
SETUP_DIR="$HOME/.local/scripts/new_machine_setup"

echo "Starting Full System Setup..."

# Execute sub-scripts
# Using 'bash' explicitly ensures they run even if +x permission was lost during git sync
bash "$SETUP_DIR/packages_install"
bash "$SETUP_DIR/repos_install"
bash "$SETUP_DIR/uwsm_setup"
bash "$SETUP_DIR/nerd_font"

# We might want to let the script continue even if battery_threshold fails 
# (e.g., if running on a desktop)
bash "$SETUP_DIR/battery_threshold" || echo "Warning: Battery threshold setup skipped."

# --- Shell Change ---
if [[ "$SHELL" != "$(which zsh)" ]]; then
    echo "Changing default shell to zsh..."
    sudo chsh -s "$(which zsh)" "$USER"
fi

# --- Post-Install Tasks ---
echo "Running post-install tasks..."

if command -v starship &> /dev/null; then
    echo "Configuring starship with plain text symbols..."
    starship preset plain-text-symbols -o ~/.config/starship.toml
else
    echo "Warning: starship prompt cli not found."
fi

echo "Starting system cleanup..."
sudo dnf autoremove -y

echo "Cleaning up dnf cache..."
sudo dnf clean all

echo "Post-install tasks completed!"

echo -e "\n---------------------------"
echo -e "\033[1;32mMain installation finished!\033[0m"
echo -e "Please \033[1mreboot\033[0m your system to finalize all changes."
