#!/usr/bin/env bash

# Exit on error, unset variables, and pipe failures
set -Eeuo pipefail
# Trap for clean exit
trap cleanup SIGINT SIGTERM ERR EXIT

# --- Configuration & Defaults ---
location=""
repository=""
foldername=""

# --- Utility Functions ---

usage() {
    cat << EOF
Usage: $(basename "${BASH_SOURCE[0]}") [-h] [-v] [-l location] repository [foldername]

Clones a bare repo and prepares it for a worktree-only workflow.
EOF
    exit
}

cleanup() {
    trap - SIGINT SIGTERM ERR EXIT
}

setup_colors() {
    if [[ -t 2 ]] && [[ -z "${NO_COLOR-}" ]] && [[ "${TERM-}" != "dumb" ]]; then
        # Added PURPLE and CYAN here
        NOFORMAT='\033[0m' RED='\033[0;31m' GREEN='\033[0;32m' ORANGE='\033[0;33m' \
        BLUE='\033[0;34m' PURPLE='\033[0;35m' CYAN='\033[0;36m' YELLOW='\033[1;33m'
    else
        # Critical: You must also define them as empty strings here for 'set -u' to pass
        NOFORMAT='' RED='' GREEN='' ORANGE='' BLUE='' PURPLE='' CYAN='' YELLOW=''
    fi
}

msg() { echo >&2 -e "${1-}"; }

die() {
    local msg=$1
    local code=${2-1}
    msg "${RED}Error: $msg${NOFORMAT}"
    exit "$code"
}

parse_params() {
    while :; do
        case "${1-}" in
            -h | --help) usage ;;
            -v | --verbose) set -x ;;
            -l | --location) location="${2-}"; shift ;;
            -?*) die "Unknown option: $1" ;;
            *) break ;;
        esac
        shift
    done

    [[ $# -lt 1 ]] && die "Missing repository URL"
    
    repository="${1}"

    # --- THE FIX: Sanitizing the folder name ---
    # 1. Strip the .git suffix if present
    local base_name="${repository%.git}"
    
    # 2. Handle Aliases (everything before the last colon)
    # If the string contains a ':', take everything after the LAST one.
    if [[ "$base_name" == *:* ]]; then
        base_name="${base_name##*:}"
    fi

    # 3. Handle Paths (everything before the last slash)
    # This handles standard URLs like https://github.com/user/repo
    base_name="${base_name##*/}"
    # --------------------------------------------

    foldername="${2:-$base_name}"
    location="${location:-$foldername}"
}

# --- Main Logic ---

parse_params "$@"
setup_colors

if [[ -d "$location" ]]; then
    die "Target directory '$location' already exists."
fi

msg "${YELLOW}Cloning bare repository...${NOFORMAT}"
# --filter=blob:none creates a blobless partial clone (ideal for performance)
git clone --bare --filter=blob:none "${repository}" "${location}"

# Move into the bare repo
cd "${location}"

msg "${YELLOW}Configuring for worktree-exclusive workflow...${NOFORMAT}"

# 1. Fix the Refspec: This allows 'git branch -a' to see remote branches
# and allows 'git fetch' to work like a normal repo.
git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

# 2. Enable worktree-specific config:
# This allows you to have different Git settings per worktree.
git config extensions.worktreeConfig true

# 3. Optimization: Set up the default 'main' or 'master' tracking
# This prevents 'git status' from being confused on first checkout.
git fetch origin

msg "${GREEN}Successfully prepared bare repository at: ${PURPLE}$(pwd)${NOFORMAT}"
msg "${CYAN}Next step: git worktree add main${NOFORMAT}"
