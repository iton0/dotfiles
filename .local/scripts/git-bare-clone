#!/usr/bin/env bash
#-----------------------------
# BARE GIT CLONE SCRIPT
#-----------------------------
# This script automates the process of cloning a bare Git repository
# and setting it up for exclusive use with worktrees.
# It uses a standard bash script boilerplate for robust error handling and
# parameter parsing.

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

#==============================
# SCRIPT UTILITY FUNCTIONS
#==============================

# Display the script usage information and exit.
usage() {
    cat << EOF
Usage: $(basename "${BASH_SOURCE[0]}") [-h] [-v] [-l location] repository [foldername]
Clone a bare git repo and set up environment for working comfortably and exclusively from worktrees.

Positional arguments:
  repository      URL of the repository to clone
  foldername      Name of the folder where the repository will be cloned (optional)

Options:
  -h, --help       Print this help and exit
  -v, --verbose    Print script debug info
  -l, --location   Location of the bare repo contents (if not provided, defaults to foldername)
EOF
    exit
}

# Clean up resources on script exit.
cleanup() {
    trap - SIGINT SIGTERM ERR EXIT
}

# Set up terminal colors for better output formatting.
setup_colors() {
    if [[ -t 2 ]] && [[ -z "${NO_COLOR-}" ]] && [[ "${TERM-}" != "dumb" ]]; then
        NOFORMAT='\033[0m' RED='\033[0;31m' GREEN='\033[0;32m' ORANGE='\033[0;33m' BLUE='\033[0;34m' PURPLE='\033[0;35m' CYAN='\033[0;36m' YELLOW='\033[1;33m'
    else
        NOFORMAT='' RED='' GREEN='' ORANGE='' BLUE='' PURPLE='' CYAN='' YELLOW=''
    fi
}

# Print a message to standard error.
msg() {
    echo >&2 -e "${1-}"
}

# Print an error message and exit with a given status code.
die() {
    local msg=$1
    local code=${2-1} # default exit status 1
    msg "$msg"
    exit "$code"
}

# Parse command line parameters and validate them.
parse_params() {
    while :; do
        case "${1-}" in
            -h | --help) usage ;;
            -v | --verbose) set -x ;;
            --no-color) NO_COLOR=1 ;;
            -l | --location)
                location="${2-}"
                shift
                ;;
            -?*) die "Unknown option: $1" ;;
            *) break ;;
        esac
        shift
    done

    # Check for the correct number of positional arguments.
    if [[ $# -lt 1 || $# -gt 2 ]]; then
        die "Invalid number of arguments: expected repository URL and optionally folder name"
    fi

    repository="${1}"
    foldername="${2:-$(basename "${repository}")}"
    location="${location:-$foldername}"

    return 0
}


#==============================
# MAIN SCRIPT LOGIC
#==============================

parse_params "$@"
setup_colors

# Clone the repository with the --bare and --filter flags.
msg "${YELLOW}Cloning bare repository from ${repository} to ${foldername}...${NOFORMAT}"
git clone --bare --filter=blob:none "${repository}" "${foldername}"

# Navigate into the new bare repository directory.
pushd "${foldername}" > /dev/null

# Adjust the fetch configuration for the origin remote.
msg "${YELLOW}Adjusting origin fetch locations...${NOFORMAT}"
git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

# Navigate back to the original directory.
popd > /dev/null

# Change into the cloned repository to perform subsequent operations.
cd "${foldername}"

# Fetch the latest changes.
git fetch

# Print a success message.
msg "${GREEN}Success.${NOFORMAT}"
