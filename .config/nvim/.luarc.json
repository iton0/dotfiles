{
  "runtime": {
    "version": "LuaJIT",
    "path": ["lua/?.lua", "lua/?/init.lua"]
  },
  "diagnostics": {
    "globals": ["vim"]
  },
  "workspace": {
    "checkThirdParty": false,
    "library": [
      "bit",
      "jit",
      "lua"
    ],
    "maxPreload": 1000,
    "preloadFileSize": 100
  }
}
