# This is a combined Sway configuration based on your custom preferences
# and the default Sway configuration.
#
# Your custom settings override or replace the defaults where they overlap.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4

# Define keyboard direction keys for navigation (from default config)
set $left h
set $down j
set $up k
set $right l

# Your custom font variable (from your custom config)
set $my_font pango:JetBrainsMono Nerd Font 24

# laptop display name
set $laptop eDP-1

# Your preferred terminal emulator (from your custom config)
set $term footclient

# Your preferred application launcher (from your custom config)
# The '$my_font' variable is now correctly defined before it is used here.
set $rofi_cmd rofi -terminal '$term'
set $menu $rofi_cmd \
    -modes "drun,window" \
    -show drun \
    -font "$my_font" \
    -run-command "uwsm app -- {cmd}"

### Output configuration
#
# Default wallpaper (from default config)
output * bg /usr/share/backgrounds/default.jxl fill

### Startup applications and services
#
# `exec` for startup commands.
# Your custom list of startup applications and services.
assign [app_id="footclient"] 1
# Start the foot terminal server
exec foot --server
exec sh -c 'while [ ! -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/foot-${WAYLAND_DISPLAY:-wayland-0}.sock" ]; do sleep 0.01; done; uwsm app -- footclient'
# Launching applications on specific workspaces (from your custom config)
exec swaymsg "workspace 2; exec uwsm app -- firefox"



### Idle configuration
#
exec swayidle -w \
    timeout 150 'brightnessctl -s set 10%' resume 'brightnessctl -r' \
    timeout 300 'loginctl lock-session' \
    timeout 600 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
    timeout 1200 'systemctl suspend' \
    before-sleep 'loginctl lock-session'

exec_always ~/.local/scripts/clamshell
exec_always killall swaync; sleep 1; swaync &

### Input configuration
#
input "type:keyboard" {
    xkb_layout us
    xkb_options caps:escape
}
# Enable natural scrolling for all devices
input "*" natural_scroll enabled

# Disable natural scrolling specifically for the touchpad
input "type:touchpad" {
    natural_scroll disabled
}

# hide this cursor while typing
seat * hide_cursor when-typing enable

### Window settings
#
# Window borders and gaps (from your custom config)
gaps inner 4
smart_gaps inverse_outer
smart_borders on

# window colors (from your custom config)

# Window rules (from your custom config)
for_window [workspace="^w\[tv1\]$" floating=0] border pixel 0
for_window [workspace="^f\[1\]$" floating=0] border pixel 0

# Drag floating windows (from default config)
floating_modifier $mod normal

### Key bindings
#
# Your custom bindings will be listed first to ensure they take precedence.
# The default bindings that do not conflict will be added after.

# Custom bindings from your Hyprland config
bindsym $mod+Return exec uwsm app -- $term
bindsym $mod+q kill
bindsym $mod+f fullscreen toggle
bindsym $mod+d exec uwsm app -- $menu
bindsym $mod+z exec systemctl suspend
bindsym $mod+n exec swaync-client -t

bindsym $mod+p exec uwsm app -- grim && notify-send "Grim" "Screenshot taken"
bindsym $mod+Shift+p exec uwsm app -- grim -g "$(slurp)" && notify-send "Grim" "Region screenshot taken"

# Default bindings from the Sway config that don't conflict

# Reload
bindsym $mod+Shift+c reload
# Moving focus around
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
# Ditto, with arrow keys
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move the focused window
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
# Ditto, with arrow keys
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Move container to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Custom special workspace (from your custom config)

# Layout stuff
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Toggling between tiling and floating
bindsym $mod+Shift+space floating toggle

# Swap focus between the tiling area and the floating area
bindsym $mod+space focus mode_toggle

# Move focus to the parent container
bindsym $mod+a focus parent

bindsym $mod+t exec ~/.local/scripts/toggle-system-theme

# Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Resizing containers
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

bindswitch --reload --locked lid:on output $laptop disable
bindswitch --reload --locked lid:off output $laptop enable

# Include configs from other files (from default config)
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'
